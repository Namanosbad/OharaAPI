@page "/autores/{Id:guid}"
@using Ohara.API.Shared.Responses
@inject AutorService AutorService
@inject NavigationManager Nav

<div class="adventure-container">
    @if (autor == null)
    {
        <div class="loading-msg">Consultando os arquivos de Ohara...</div>
    }
    else
    {
        <div class="autor-detalhe">
            <h2 class="page-title">Dossiê de @autor.Nome</h2>

            <div class="autor-card">
                <div class="autor-inicial">@ObterInicial(autor.Nome)</div>
                <div>
                    <p><strong>ID:</strong> @autor.Id</p>
                    <p><strong>Livros no acervo:</strong> @autor.Livros?.Count</p>
                </div>
            </div>

            <h3>Livros Registrados</h3>

            @if (autor.Livros == null || !autor.Livros.Any())
            {
                <p>Nenhum livro registrado em Ohara.</p>
            }
            else
            {
                <ul class="lista-livros">
                    @foreach (var livro in autor.Livros)
                    {
                        <li class="livro-item">
                            <div class="livro-item-topo">
                                <strong class="livro-titulo">@livro.Titulo</strong>
                                <span class="livro-genero">@livro.Genero</span>
                            </div>

                            <div class="livro-meta">
                                <span>📅 @livro.DataPublicacao:dd/MM/yyyy</span>
                                <span>📦 @(livro.Disponivel ? "Disponível" : "Indisponível")</span>
                            </div>

                            <a class="btn-livro-detalhe" href="@($"/livros/{livro.Id}")">Ver detalhes do livro</a>
                        </li>
                    }
                </ul>
            }
        </div>
    }

    <button class="back-scroll" @onclick="Voltar">
        ← Voltar aos Autores
    </button>
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private AutorResponse? autor;

    protected override async Task OnInitializedAsync()
    {
        autor = await AutorService.ObterPorId(Id);
    }

    private void Voltar() => Nav.NavigateTo("/autores");
    private static string ObterInicial(string? nome) =>
    string.IsNullOrWhiteSpace(nome) ? "?" : nome.Substring(0, 1).ToUpperInvariant();
}
