@page "/livros/{Id:guid}"
@using Ohara.API.Shared.Responses
@inject LivroService LivroService
@inject NavigationManager Nav

<div class="adventure-container">
    @if (carregando)
    {
        <div class="loading-msg">Localizando tomo nos registros de Ohara...</div>
    }
    else if (livro == null)
    {
        <div class="error-msg">⚠️ Livro não encontrado.</div>
    }
    else
    {
        <div class="autor-detalhe livro-detalhe">
            <h2 class="page-title">@livro.Titulo</h2>
            <p class="livro-subtitulo">@ObterNomeAutor() · @livro.Genero</p>

            <div class="livro-highlight">
                <span class="livro-badge">📅 @livro.DataPublicacao.ToString("dd/MM/yyyy")</span>
                <span class="livro-badge">🌐 @ObterIdioma()</span>
                <span class="livro-badge @(livro.Disponivel ? "livro-badge-disponivel" : "livro-badge-indisponivel")">
                    📦 @(livro.Disponivel ? "Disponível" : "Indisponível")
                </span>
            </div>

            <div class="livro-grid-info">
                <p><strong>Autor:</strong> @ObterNomeAutor()</p>
                <p><strong>Gênero:</strong> @livro.Genero</p>
                <p><strong>Assunto:</strong> @ObterAssunto()</p>
                <p><strong>Idioma:</strong> @ObterIdioma()</p>
                <p><strong>ISBN:</strong> @ObterIsbn()</p>
                <p><strong>Data de publicação:</strong> @livro.DataPublicacao.ToString("dd/MM/yyyy")</p>
                <p><strong>Disponibilidade:</strong> @(livro.Disponivel ? "Disponível" : "Indisponível")</p>
            </div>

            <h3>Descrição</h3>
            <p class="livro-descricao">@ObterDescricao()</p>
        </div>
    }

    <button class="back-scroll" @onclick="Voltar">← Voltar aos Livros</button>
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private LivroResponse? livro;
    private bool carregando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            livro = await LivroService.ObterPorId(Id);
        }
        finally
        {
            carregando = false;
        }
    }
    private string ObterNomeAutor() => !string.IsNullOrWhiteSpace(livro?.NomeAutor) ? livro.NomeAutor! : "Autor não informado";
    private string ObterIdioma() => !string.IsNullOrWhiteSpace(livro?.Idioma) ? livro.Idioma! : "Idioma não informado";
    private string ObterAssunto() => !string.IsNullOrWhiteSpace(livro?.Assunto) ? livro.Assunto! : "Não informado";
    private string ObterIsbn() => !string.IsNullOrWhiteSpace(livro?.ISBN) ? livro.ISBN! : "Não informado";
    private string ObterDescricao() => !string.IsNullOrWhiteSpace(livro?.Descricao) ? livro.Descricao! : "Sem descrição registrada.";
    private void Voltar() => Nav.NavigateTo("/livros");
}